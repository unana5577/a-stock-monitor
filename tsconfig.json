{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": ["server.js", "public/**/*.js", "ai.js", "global.d.ts"],
  "exclude": ["public/libs/**"]
}
